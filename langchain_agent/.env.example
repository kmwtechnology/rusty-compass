# Environment Configuration Example
# Copy this file to .env and adjust values as needed

# API Security (REQUIRED - authentication is always enforced)
# Generate a secure random key for production use
API_KEY=your-secure-api-key-here

# Google AI Configuration (REQUIRED)
# Get your API key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# PostgreSQL Configuration (checkpoints and conversation metadata)
# Local dev: Docker container on localhost
# GCP: Cloud SQL configured in deploy.sh
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=langchain_agent

# OpenSearch Configuration (document storage and hybrid search)
# Local dev: Docker container on localhost (no auth, no SSL)
# GCP: Hosted instance configured in deploy.sh
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX_NAME=rusty_compass_docs

# LLM Model Selection (Google Gemini)
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0

# Embeddings Model (must match vector dimension in config)
EMBEDDINGS_MODEL=models/gemini-embedding-001

# Reranker Model (Gemini LLM-as-reranker)
RERANKER_MODEL=gemini-2.5-flash-lite

# Retrieval Configuration
RETRIEVER_K=4                    # Final documents to return
RETRIEVER_FETCH_K=30             # Candidates to fetch before reranking
RETRIEVER_ALPHA=0.25             # Hybrid search: 0.0 = pure lexical/BM25, 1.0 = pure semantic/vector

# Reranker Configuration
ENABLE_RERANKING=true            # Always enabled for best quality
RERANKER_FETCH_K=15              # Candidates to rerank
RERANKER_TOP_K=4                 # Final documents after reranking

# Query Evaluation
ENABLE_QUERY_EVALUATION=true     # Dynamic alpha based on query type
QUERY_EVAL_TIMEOUT_MS=3000       # Timeout for query evaluation

# Conversation Settings
DEFAULT_THREAD_ID=default_thread
ENABLE_COMPACTION=true           # Smart context management for long conversations
MAX_CONTEXT_TOKENS=3000          # Conservative estimate for context window

# Logging
LOG_LEVEL=INFO                   # Options: DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=console               # Options: console (dev), json (production)

# LangSmith Observability (optional - for tracing and debugging)
# Get API key from https://smith.langchain.com
# LANGSMITH_API_KEY=your-langsmith-api-key
# LANGSMITH_PROJECT=rusty-compass

# Advanced Streaming (experimental)
# Enable token-level streaming via LangGraph's astream_events v2 API
# ENABLE_ASTREAM_EVENTS=false

# Frontend Configuration
# VITE_API_KEY is auto-set by setup.sh (matches API_KEY above)
# VITE_API_URL: Set for local dev when frontend/backend run on different ports
# In production (Cloud Run), leave unset — frontend uses relative URLs
# VITE_API_URL=http://localhost:8000

# CORS Origins (comma-separated, for production Cloud Run URL)
# CORS_ORIGINS=https://rusty-compass-xxxx-uc.a.run.app

# Config Builder (Lucille Pipeline Configuration Generation)
# LUCILLE_PROJECT_DIR: Path to Lucille source repository
# Default: ../lucille (relative to langchain_agent/)
# Required for: Config validation via Java validator, component catalog extraction
# LUCILLE_PROJECT_DIR=../lucille

# Config Validation Options
ENABLE_CONFIG_VALIDATION=true       # Validate generated configs via Lucille's Java validator
CONFIG_VALIDATION_MAX_RETRIES=2     # Retries when validation fails (0 = no retries)
CONFIG_VALIDATION_TIMEOUT=30        # Timeout for Java validator in seconds

# Advanced (rarely changed)
VECTOR_DIMENSION=768             # gemini-embedding-001 with output_dimensionality=768
